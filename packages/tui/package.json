{
  "name": "@lordcode/tui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "lordcode": "./bin/lordcode.js"
  },
  "scripts": {
    "predev": "pnpm --filter @lordcode/server build",
    "dev": "tsx --tsconfig tsconfig.dev.json src/main.tsx",
    "start": "node dist/main.js",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@lordcode/server": "workspace:*",
    "@lordcode/shared": "workspace:*",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
