{
  "name": "@lordcode/tui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "lordcode": "./bin/lordcode.js"
  },
  "scripts": {
    "predev": "pnpm --filter @lordcode/server build",
    "dev": "tsx --tsconfig tsconfig.dev.json src/main.tsx",
    "start": "node dist/main.js",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@lordcode/logger": "workspace:*",
    "@lordcode/server": "workspace:*",
    "@lordcode/shared": "workspace:*",
    "eventsource-parser": "^3.0.8",
    "ink": "^7.0.2",
    "react": "^19.2.0",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
